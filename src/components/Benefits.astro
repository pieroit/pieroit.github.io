---
import { Icon } from 'astro-icon/components'

interface BenefitItem {
  icon: string
  title: string
  description: string
}

const { items } = Astro.props as { items: BenefitItem[] }
---

<div class="mx-auto max-w-xl py-12">
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    {
      items.map((i: BenefitItem) => {
        return (
          <div class="flex items-center gap-6 px-4">
            <div>
              <Icon name={i.icon} class="size-16" />
            </div>
            <div>
              <h3 class="text-lg font-semibold">{i.title}</h3>
              <p class="mt-1 text-sm text-gray-600">{i.description}</p>
            </div>
          </div>
        )
      })
    }
  </div>
</div>
