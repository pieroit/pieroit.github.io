---
import Carousel from '@/components/ui/carousel.jsx'

const items = [
    {
        url: 'sonycsl.png',
        alt: 'Sony CSL',
    },
    {
        url: 'greenpeace.png',
        alt: 'GreenPeace',
    },
    {
        url: 'linux_day.png',
        alt: 'Linux Day',
    },
    {
        url: 'tedx.png',
        alt: 'TedX',
    },
    {
        url: 'codemotion.png',
        alt: 'Codemotion',
    },
    {
        url: 'cnr.png',
        alt: 'Italian National Research Council',
    },
    {
        url: 'cheshirecatai.png',
        alt: 'Cheshire Cat AI',
    },
]

const settings = {
    infinite: true, // enables infinite loop
    speed: 5000, // long transition duration for smoothness
    autoplay: true, // enable auto-scrolling
    autoplaySpeed: 0, // no delay between scrolls
    cssEase: 'linear', // linear easing for constant speed
    slidesToShow: 1, // number of slides visible at once
    slidesToScroll: 1, // scroll one slide at a time
    variableWidth: true, // optional: allows slides to have different widths
}
---

<Carousel client:only="react" items={items} settings={settings} />
