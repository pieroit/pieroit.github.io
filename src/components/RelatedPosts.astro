---
import BlogCard from '@/components/BlogCard.astro'
import { getRelatedPosts } from '@/lib/data-utils'

interface Props {
  postId: string
  count?: number
}

const { postId, count = 3 } = Astro.props
const related = await getRelatedPosts(postId, count)
---

{
  related.length > 0 && (
    <div class="col-start-2 flex flex-col gap-4">
      <h2 class="text-2xl font-medium">Related posts</h2>
      <div class="flex flex-col gap-4">
        {related.map((post) => (
          <BlogCard entry={post} />
        ))}
      </div>
    </div>
  )
}
