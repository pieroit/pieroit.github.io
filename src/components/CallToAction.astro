---
import Link from './Link.astro'
import { Button, buttonVariants } from './ui/button'
import { cn } from '@/lib/utils'

const { title, description, cta, href } = Astro.props
---

<div class="py-12 px-6 text-center max-w-xl mx-auto">
    <h1 class="mb-2 text-4xl leading-tight font-medium text-pretty sm:text-5xl">{title}</h1>
    <p class="text-gray-700 mb-6">{description}</p>
    {
        href ? (
            <Link href={href} external class={cn(buttonVariants(), 'px-6 py-3')}>
                {cta}
            </Link>
        ) : (
            <Button className="px-6 py-3">{cta}</Button>
        )
    }
</div>
